{
    "name": "lapisense/wordpress-client",
    "description": "WordPress client for the Lapisense licensing API",
    "type": "library",
    "license": "MIT",
    "repositories": [
        { "type": "path", "url": "../php-client" }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=7.4",
        "lapisense/php-client": "^1.0 || dev-main"
    },
    "autoload": {
        "psr-4": {
            "Lapisense\\WordPressClient\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "phpcompatibility/php-compatibility": "^9.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
        "squizlabs/php_codesniffer": "^3.13",
        "phpmd/phpmd": "^2.15"
    }
}
