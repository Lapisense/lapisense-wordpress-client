{
    "name": "lapisense/wordpress-client",
    "description": "WordPress client for the Lapisense licensing API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "lapisense/php-client": "^0.2 || ^1.0"
    },
    "autoload": {
        "psr-4": {
            "Lapisense\\WordPressClient\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lapisense\\WordPressClient\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpcompatibility/php-compatibility": "^9.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
        "squizlabs/php_codesniffer": "^3.13",
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "phpmd/phpmd": "^2.15",
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.7"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "mkdir -p build && vendor/bin/phpunit --coverage-text --coverage-clover build/coverage.xml",
        "test:coverage-enforce": [
            "@test:coverage",
            "@php scripts/check-coverage.php"
        ],
        "lint": "vendor/bin/phpcs",
        "analyse": "vendor/bin/phpstan analyse",
        "mess": "vendor/bin/phpmd src text phpmd.xml.dist"
    }
}
